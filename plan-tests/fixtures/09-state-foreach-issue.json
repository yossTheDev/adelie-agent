{
  "name": "STATE functions inside FOR_EACH - reproducing reported issue",
  "plan": [
    {
      "id": "setup",
      "action": "CREATE_FILE",
      "args": {
        "path": "__ROOT__\\state\\test1.txt",
        "content": "Hello from file 1"
      }
    },
    {
      "id": "setup2", 
      "action": "CREATE_FILE",
      "args": {
        "path": "__ROOT__\\state\\test2.txt",
        "content": "Hello from file 2"
      }
    },
    {
      "id": "f1",
      "action": "FILTER_FILES",
      "args": {
        "path": "__ROOT__\\state",
        "pattern": "^test.*"
      }
    },
    {
      "id": "for1",
      "action": "FOR_EACH",
      "args": {
        "items": "$$f1",
        "template": [
          {
            "id": "r1",
            "action": "READ_FILE",
            "args": {
              "path": "$$item"
            }
          },
          {
            "id": "s1",
            "action": "STATE_APPEND",
            "args": {
              "key": "content_buffer",
              "content": "$$r1"
            }
          }
        ]
      }
    },
    {
      "id": "g1",
      "action": "STATE_GET",
      "args": {
        "key": "content_buffer"
      }
    },
    {
      "id": "verify",
      "action": "CREATE_FILE",
      "args": {
        "path": "__ROOT__\\state\\result.txt",
        "content": "Final buffer content: $$g1"
      }
    }
  ]
}
