{
  "name": "Memory Integration with DataPiping and Logic",
  "description": "Test memory operations with DataPiping, IF conditions, and loops",
  "plan": [
    {
      "id": "store_user_data",
      "action": "MEMORY_SET",
      "args": {
        "key": "user_profile",
        "value": {
          "name": "Alice",
          "role": "developer",
          "preferences": ["typescript", "react", "node"]
        },
        "source": "integration_test"
      }
    },
    {
      "id": "memory_list_check",
      "action": "MEMORY_LIST",
      "args": {}
    },
    {
      "id": "check_developer_role",
      "action": "IF",
      "args": {
        "condition": "developer",
        "then": [
          {
            "id": "store_dev_preference",
            "action": "MEMORY_SET",
            "args": {
              "key": "dev_tools",
              "value": ["vscode", "git", "docker"],
              "source": "conditional_set"
            }
          }
        ]
      }
    },
    {
      "id": "iterate_preferences",
      "action": "FOR_EACH",
      "args": {
        "items": ["typescript", "react", "node"],
        "template": [
          {
            "id": "store_individual_preference",
            "action": "MEMORY_SET",
            "args": {
              "key": "preference_$$item",
              "value": "$$item",
              "source": "loop_set"
            }
          }
        ]
      }
    },
    {
      "id": "memory_stats_final",
      "action": "MEMORY_STATS",
      "args": {}
    }
  ],
  "expectedResults": {
    "store_user_data": "Stored value in memory under key 'user_profile'",
    "memory_list_check": "Memory keys listed successfully",
    "check_developer_role": "IF condition evaluated successfully",
    "store_dev_preference": "Stored value in memory under key 'dev_tools'",
    "get_dev_tools": ["vscode", "git", "docker"],
    "iterate_preferences": true,
    "get_typescript_pref": true,
    "search_memory": [
      {
        "key": "pref_typescript",
        "value": true,
        "timestamp": "timestamp",
        "source": "loop_set"
      },
      {
        "key": "pref_react",
        "value": true,
        "timestamp": "timestamp",
        "source": "loop_set"
      },
      {
        "key": "pref_node",
        "value": true,
        "timestamp": "timestamp",
        "source": "loop_set"
      }
    ],
    "cleanup_test": "Cleared all memory keys"
  }
}
